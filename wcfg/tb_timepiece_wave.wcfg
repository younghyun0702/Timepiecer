<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timepiece_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timepiece" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="25000"></ZoomStartTime>
      <ZoomEndTime time="12700000"></ZoomEndTime>
      <Cursor1Time time="30000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="180"></NameColumnWidth>
      <ValueColumnWidth column_width="110"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="MSEC_TEN_DONE" time="1030000" />
      <marker label="SEC_ONE_DONE" time="10030000" />
      <marker label="SET_HOLD_DONE" time="12030000" />
      <marker label="FORMAT_TOGGLE_DONE" time="12130000" />
      <marker label="EDIT_DONE" time="12330000" />
      <marker label="APPLY_SET" time="12430000" />
      <marker label="DONE" time="12650000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timepiece/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#DCDCDC</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="group91">
      <obj_property name="label">Control</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="logic" fp_name="/tb_timepiece/rst">
         <obj_property name="ElementShortName">rst</obj_property>
         <obj_property name="ObjectShortName">rst</obj_property>
         <obj_property name="CustomSignalColor">#FF0000</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timepiece/i_set_mode">
         <obj_property name="ElementShortName">i_set_mode</obj_property>
         <obj_property name="ObjectShortName">i_set_mode</obj_property>
         <obj_property name="CustomSignalColor">#0000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timepiece/i_set_index">
         <obj_property name="ElementShortName">i_set_index[1:0]</obj_property>
         <obj_property name="ObjectShortName">i_set_index[1:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
         <obj_property name="CustomSignalColor">#8000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timepiece/i_time_24">
