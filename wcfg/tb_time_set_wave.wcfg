<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_time_set_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_time_set" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="25000"></ZoomStartTime>
      <ZoomEndTime time="495000"></ZoomEndTime>
      <Cursor1Time time="30000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="162"></NameColumnWidth>
      <ValueColumnWidth column_width="104"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="LIVE_TRACK_DONE" time="50000" />
      <marker label="SET_ENTER_DONE" time="70000" />
      <marker label="SEC_PLUS_MINUS_DONE" time="110000" />
      <marker label="SEC_TENS_DONE" time="150000" />
      <marker label="MIN_EDIT_DONE" time="200000" />
      <marker label="MIN_WRAP_DONE" time="260000" />
