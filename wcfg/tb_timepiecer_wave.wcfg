<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timepiecer_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timepiecer" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="25000"></ZoomStartTime>
      <ZoomEndTime time="30000000"></ZoomEndTime>
      <Cursor1Time time="50000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="210"></NameColumnWidth>
      <ValueColumnWidth column_width="120"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="50000" />
      <marker label="LIVE_TRACK_DONE" time="1600000" />
      <marker label="SET_ENTER_DONE" time="6000000" />
      <marker label="HOUR_EDIT_DONE" time="17000000" />
      <marker label="FORMAT_12H_DONE" time="17100000" />
      <marker label="SET_EXIT_DONE" time="21500000" />
      <marker label="TIMER_RUN_DONE" time="25000000" />
      <marker label="DISPLAY_TOGGLE_DONE" time="27400000" />
      <marker label="TIMER_CLEAR_DONE" time="29800000" />
      <marker label="DONE" time="29850000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timepiecer/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
