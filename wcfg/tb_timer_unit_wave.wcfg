<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timer_unit_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timer_unit" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0"></ZoomStartTime>
      <ZoomEndTime time="4200000000"></ZoomEndTime>
      <Cursor1Time time="30000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="190"></NameColumnWidth>
      <ValueColumnWidth column_width="110"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="RUN_START" time="100000" />
      <marker label="DOWN_MODE" time="2100000000" />
      <marker label="CLEAR_IN_RUN" time="3600000000" />
      <marker label="DONE" time="4100000000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timer_unit/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#DCDCDC</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="group1">
      <obj_property name="label">Input</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="logic" fp_name="/tb_timer_unit/rst">
         <obj_property name="ElementShortName">rst</obj_property>
         <obj_property name="ObjectShortName">rst</obj_property>
         <obj_property name="CustomSignalColor">#FF0000</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_unit/i_btnD">
         <obj_property name="ElementShortName">i_btnD</obj_property>
         <obj_property name="ObjectShortName">i_btnD</obj_property>
         <obj_property name="CustomSignalColor">#0000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_unit/i_btnL">
         <obj_property name="ElementShortName">i_btnL</obj_property>
         <obj_property name="ObjectShortName">i_btnL</obj_property>
         <obj_property name="CustomSignalColor">#0000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_unit/i_btnU">
         <obj_property name="ElementShortName">i_btnU</obj_property>
         <obj_property name="ObjectShortName">i_btnU</obj_property>
         <obj_property name="CustomSignalColor">#0000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_unit/i_sw0">
         <obj_property name="ElementShortName">i_sw0</obj_property>
         <obj_property name="ObjectShortName">i_sw0</obj_property>
         <obj_property name="CustomSignalColor">#8000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="group2">
      <obj_property name="label">Conditioned</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="logic" fp_name="/tb_timer_unit/w_btnD">
         <obj_property name="ElementShortName">w_btnD</obj_property>
         <obj_property name="ObjectShortName">w_btnD</obj_property>
         <obj_property name="CustomSignalColor">#00AA00</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_unit/w_btnL">
         <obj_property name="ElementShortName">w_btnL</obj_property>
         <obj_property name="ObjectShortName">w_btnL</obj_property>
         <obj_property name="CustomSignalColor">#00AA00</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_unit/w_btnU">
         <obj_property name="ElementShortName">w_btnU</obj_property>
         <obj_property name="ObjectShortName">w_btnU</obj_property>
         <obj_property name="CustomSignalColor">#00AA00</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="group3">
      <obj_property name="label">Timer Output</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="array" fp_name="/tb_timer_unit/hour">
         <obj_property name="ElementShortName">hour[4:0]</obj_property>
         <obj_property name="ObjectShortName">hour[4:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timer_unit/min">
         <obj_property name="ElementShortName">min[5:0]</obj_property>
         <obj_property name="ObjectShortName">min[5:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timer_unit/sec">
         <obj_property name="ElementShortName">sec[5:0]</obj_property>
         <obj_property name="ObjectShortName">sec[5:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timer_unit/msec">
         <obj_property name="ElementShortName">msec[6:0]</obj_property>
         <obj_property name="ObjectShortName">msec[6:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
   </wvobject>
</wave_config>
