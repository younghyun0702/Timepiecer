<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timer_datapath_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timer_datapath" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0"></ZoomStartTime>
      <ZoomEndTime time="220000000"></ZoomEndTime>
      <Cursor1Time time="30000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="190"></NameColumnWidth>
      <ValueColumnWidth column_width="110"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="RUN_START" time="50000" />
      <marker label="CLEAR_ON" time="101000000" />
      <marker label="DOWN_MODE" time="112000000" />
      <marker label="DONE" time="210000000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timer_datapath/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#DCDCDC</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="group1">
      <obj_property name="label">Control</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="logic" fp_name="/tb_timer_datapath/rst">
         <obj_property name="ElementShortName">rst</obj_property>
         <obj_property name="ObjectShortName">rst</obj_property>
         <obj_property name="CustomSignalColor">#FF0000</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_datapath/i_runstop">
         <obj_property name="ElementShortName">i_runstop</obj_property>
         <obj_property name="ObjectShortName">i_runstop</obj_property>
         <obj_property name="CustomSignalColor">#0000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_datapath/i_clear">
         <obj_property name="ElementShortName">i_clear</obj_property>
         <obj_property name="ObjectShortName">i_clear</obj_property>
         <obj_property name="CustomSignalColor">#FFA500</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timer_datapath/i_updown">
         <obj_property name="ElementShortName">i_updown</obj_property>
         <obj_property name="ObjectShortName">i_updown</obj_property>
         <obj_property name="CustomSignalColor">#8000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="group2">
      <obj_property name="label">Timer Output</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="array" fp_name="/tb_timer_datapath/hour">
         <obj_property name="ElementShortName">hour[4:0]</obj_property>
         <obj_property name="ObjectShortName">hour[4:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timer_datapath/min">
         <obj_property name="ElementShortName">min[5:0]</obj_property>
         <obj_property name="ObjectShortName">min[5:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timer_datapath/sec">
         <obj_property name="ElementShortName">sec[5:0]</obj_property>
         <obj_property name="ObjectShortName">sec[5:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timer_datapath/msec">
         <obj_property name="ElementShortName">msec[6:0]</obj_property>
         <obj_property name="ObjectShortName">msec[6:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
      </wvobject>
   </wvobject>
</wave_config>
