<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_timepiece_fsm_behav.wdb" id="1">
         <top_modules>
            <top_module name="glbl" />
            <top_module name="tb_timepiece_fsm" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="25000"></ZoomStartTime>
      <ZoomEndTime time="180000"></ZoomEndTime>
      <Cursor1Time time="30000"></Cursor1Time>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="180"></NameColumnWidth>
      <ValueColumnWidth column_width="110"></ValueColumnWidth>
   </column_width_setting>
   <WVObjectSize size="5" />
   <wave_markers>
      <marker label="RESET_OFF" time="30000" />
      <marker label="SET_ENTER" time="50000" />
      <marker label="INDEX_SHIFT_DONE" time="70000" />
      <marker label="INC_DONE" time="90000" />
      <marker label="INC_TENS_DONE" time="110000" />
      <marker label="DEC_DONE" time="130000" />
      <marker label="DEC_TENS_DONE" time="150000" />
      <marker label="SET_EXIT_DONE" time="160000" />
      <marker label="SW0_FORCE_VIEW" time="180000" />
   </wave_markers>
   <wvobject type="logic" fp_name="/tb_timepiece_fsm/clk">
      <obj_property name="ElementShortName">clk</obj_property>
      <obj_property name="ObjectShortName">clk</obj_property>
      <obj_property name="CustomSignalColor">#DCDCDC</obj_property>
      <obj_property name="UseCustomSignalColor">true</obj_property>
   </wvobject>
   <wvobject type="group" fp_name="group81">
      <obj_property name="label">Control</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="logic" fp_name="/tb_timepiece_fsm/rst">
         <obj_property name="ElementShortName">rst</obj_property>
         <obj_property name="ObjectShortName">rst</obj_property>
         <obj_property name="CustomSignalColor">#FF0000</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timepiece_fsm/i_sw0">
         <obj_property name="ElementShortName">i_sw0</obj_property>
         <obj_property name="ObjectShortName">i_sw0</obj_property>
         <obj_property name="CustomSignalColor">#FFA500</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timepiece_fsm/o_set_mode">
         <obj_property name="ElementShortName">o_set_mode</obj_property>
         <obj_property name="ObjectShortName">o_set_mode</obj_property>
         <obj_property name="CustomSignalColor">#0000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="array" fp_name="/tb_timepiece_fsm/o_set_index">
         <obj_property name="ElementShortName">o_set_index[1:0]</obj_property>
         <obj_property name="ObjectShortName">o_set_index[1:0]</obj_property>
         <obj_property name="Radix">UNSIGNEDDECRADIX</obj_property>
         <obj_property name="CustomSignalColor">#8000FF</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="group82">
      <obj_property name="label">Input Action</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="logic" fp_name="/tb_timepiece_fsm/i_btnL">
