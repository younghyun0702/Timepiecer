         <obj_property name="CustomSignalColor">#FF0080</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
      <wvobject type="logic" fp_name="/tb_timepiece_fsm/i_btnR_hold">
