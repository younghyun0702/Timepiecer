         <obj_property name="CustomSignalColor">#00CC66</obj_property>
         <obj_property name="UseCustomSignalColor">true</obj_property>
      </wvobject>
   </wvobject>
   <wvobject type="group" fp_name="group83">
      <obj_property name="label">FSM State</obj_property>
      <obj_property name="DisplayName">label</obj_property>
      <obj_property name="isExpanded"></obj_property>
      <wvobject type="array" fp_name="/tb_timepiece_fsm/U0/current_state">
         <obj_property name="ElementShortName">current_state[2:0]</obj_property>
